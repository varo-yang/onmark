<film id="demo">
  <cues>
    <cue id="offer" time="500ms" />
  </cues>
  <scene id="opening">
    <shot id="first" duration="2s">
      <title cue="offer">Offer</title>
      <cta delay="1.5s">Act now</cta>
    </shot>
    <shot id="second" duration="1s">
      <title>Closing</title>
    </shot>
    <shot id="subframe" duration="0.000000001s">
      <cta>One frame</cta>
    </shot>
  </scene>
</film>
