{
  "name": "@onmark/bundler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "onmark-bundle": "./dist/src/command.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./command": {
      "default": "./dist/src/command.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-typescript-output.mjs && tsc",
    "test": "pnpm build && node --test dist/test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@onmark/authoring": "workspace:*",
    "@onmark/runtime": "workspace:*",
    "esbuild": "0.28.1"
  }
}
