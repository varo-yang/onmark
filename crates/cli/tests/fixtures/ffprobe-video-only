#!/bin/sh

entries='format=duration:stream=codec_type,codec_name,pix_fmt,duration,avg_frame_rate,r_frame_rate,nb_frames'

if [ "$#" -ne 8 ] || \
   [ "$1" != "-v" ] || [ "$2" != "error" ] || \
   [ "$3" != "-show_entries" ] || [ "$4" != "$entries" ] || \
   [ "$5" != "-of" ] || [ "$6" != "json" ] || [ "$7" != "--" ]; then
  printf 'unexpected ffprobe arguments\n' >&2
  exit 2
fi

if [ ! -f "$8" ]; then
  printf 'fixture input is not a file: %s\n' "$8" >&2
  exit 2
fi

printf '%s' '{"streams":[{"codec_type":"video","codec_name":"h264","pix_fmt":"yuv420p","duration":"2.000000","avg_frame_rate":"30/1","r_frame_rate":"30/1","nb_frames":"60"}],"format":{"duration":"2.000000"}}'
