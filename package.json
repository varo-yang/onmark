{
  "name": "onmark",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "generate": "cargo xtask schema",
    "generate:check": "cargo xtask schema --check",
    "format": "prettier --write \"packages/**/*.{ts,js,mjs,json}\" \"scripts/**/*.{js,mjs,json}\" \"conformance/browser/**/*.{ts,js,mjs,json,css,html}\" \"*.{js,mjs,json}\" \".github/workflows/*.{yml,yaml}\" pnpm-workspace.yaml",
    "format:check": "prettier --check \"packages/**/*.{ts,js,mjs,json}\" \"scripts/**/*.{js,mjs,json}\" \"conformance/browser/**/*.{ts,js,mjs,json,css,html}\" \"*.{js,mjs,json}\" \".github/workflows/*.{yml,yaml}\" pnpm-workspace.yaml",
    "lint": "oxlint packages scripts conformance/browser --ignore-pattern \"**/node_modules/**\" --ignore-pattern \"packages/runtime/src/generated/**\" --deny-warnings && node scripts/check-typescript-style.mjs",
    "test": "pnpm --recursive test",
    "typecheck": "pnpm --recursive typecheck && tsc --project conformance/browser/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "ajv": "8.20.0",
    "json-schema-to-typescript": "15.0.4",
    "oxlint": "1.73.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  }
}
