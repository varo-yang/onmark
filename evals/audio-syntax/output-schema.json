{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caseId", "screenplay"],
        "properties": {
          "caseId": { "type": "string" },
          "screenplay": { "type": "string" }
        }
      }
    }
  }
}
